{
  "name": "designme-studio",
  "version": "0.2.0",
  "private": true,
  "description": "Estudio local-first para generar, revisar y exportar prototipos de apps, software, dashboards, decks, infografías y webs.",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Designme",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron . --dev\"",
    "web": "vite --host 127.0.0.1",
    "web:e2e": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "security:audit": "npm audit --omit=dev",
    "build": "npm run typecheck && vite build",
    "desktop": "npm run build && electron .",
    "package": "npm run package:win",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:win:portable": "npm run build && electron-builder --win portable --publish never",
    "package:win:nsis": "npm run build && electron-builder --win nsis --publish never",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "ai.designme.studio",
    "productName": "Designme Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}"
    }
  }
}
