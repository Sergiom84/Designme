{
  "name": "designme-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first app and web design studio inspired by Open CoDesign and Huashu Design, without mandatory API keys.",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Designme",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron . --dev\"",
    "web": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "security:audit": "npm audit --omit=dev",
    "build": "npm run typecheck && vite build",
    "desktop": "npm run build && electron .",
    "package": "npm run build && electron-builder --win portable",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "ai.designme.studio",
    "productName": "Designme Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
