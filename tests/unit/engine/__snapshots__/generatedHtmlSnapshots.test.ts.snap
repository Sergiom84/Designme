    .tweak-dock button { width: 38px; height: 38px; padding: 0; font-weight: 900; }
    body[data-scheme="contrast"] { --paper: #111417; --surface: #1b2025; --ink: #f6f0e6; --text: #f6f0e6; --subtle: #33404a; }
