      color: var(--ink);
      background: var(--paper);
      letter-spacing: 0;
    }

    * { box-sizing: border-box; }
    html, body { min-height: 100%; margin: 0; }
    body {
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--accent) 7%, transparent), transparent 34%),
